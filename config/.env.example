# ============================================================
# Image Privacy Agent — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# LLM API Keys (at least one required for threat analysis; proxy works without them)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model overrides (optional — defaults in agent_config.yaml)
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o

# Offline/privacy mode — forces all LLM calls to Ollama (no cloud APIs)
# Set to "true" for maximum privacy (requires Ollama running locally)
PRIVACY_MODE=false

# Ollama (local LLM — free, offline, no data sent externally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Master secret for session key derivation
# CHANGE THIS before production deployment!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PRIVACY_MASTER_SECRET=change-this-before-production-deployment-use-token-hex-32

# Real upstream API base URLs (default values shown — change only if using proxies)
REAL_OPENAI_BASE_URL=https://api.openai.com
REAL_ANTHROPIC_BASE_URL=https://api.anthropic.com
REAL_OLLAMA_BASE_URL=http://localhost:11434

# Proxy server settings
PROXY_HOST=127.0.0.1
PROXY_PORT=8003
EPSILON_INT=4           # Noise strength: 2 (subtle), 4 (default), 8 (strong)
PROTECTION_MODE=pixel   # "pixel" or "combined" (pixel + DCT)

# HuggingFace (optional — enables CLIP semantic quality gate)
# Without this, SSIM+PSNR gates are used instead of CLIP
HF_TOKEN=hf_...
MODELS_DIR=./models

# Data storage
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR

# Max image size to protect (reject larger images)
MAX_IMAGE_SIZE_MB=20
